# ── GOD MODE Browser · config ─────────────────────────────────────────
# Copy this file to `.env` and fill in your keys. Never commit `.env`.

# Anthropic (Claude) — powers the AI that controls the browser
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# LiveKit — real-time voice so Claude can talk to you
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Room the desktop app joins. The LiveKit voice agent should join the same room.
LIVEKIT_ROOM=godmode

# Living Labs API — your backend (token minting + data/OSINT calls)
# The app asks this endpoint for a LiveKit access token, and can proxy
# data lookups through it. Adjust paths in agent/claude.js if yours differ.
LIVING_LABS_API_URL=https://api.your-living-labs.example
LIVING_LABS_API_KEY=
